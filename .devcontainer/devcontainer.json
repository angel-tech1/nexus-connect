{
	"name": "Nexus Connect — Kotlin/JVM + IntelliJ IDEA",
	"image": "mcr.microsoft.com/devcontainers/kotlin:1-21-jdk-noble",

	"features": {
		"ghcr.io/devcontainers/features/java:1": {
			"version": "21",
			"jdkDistro": "temurin"
		},
		"ghcr.io/devcontainers-extra/features/intellij-idea-enterprise:2": {
			"version": "latest"
		}
	},

	"customizations": {
		"vscode": {
			"settings": {
				"kotlin.languageServer.externalOptions.global.jdk": "/usr/lib/jvm/temurin-21-jdk-amd64",
				"java.jdt.ls.java.home": "/usr/lib/jvm/temurin-21-jdk-amd64"
			},
			"extensions": [
				"kotlin.kotlin-ide"
			]
		},
		"intellij-idea": {
			"plugins": [
				"org.jetbrains.kotlin",
				"redhat.java",
				"vscjava.vscode-maven",
				"gradle.idea-plugin"
			]
		}
	},

	"forwardPorts": [8080],

	"containerEnv": {
		"AWS_ENDPOINT_URL": "http://localhost:4566",
		"AWS_DEFAULT_REGION": "us-east-1",
		"AWS_ACCESS_KEY_ID": "test",
		"AWS_SECRET_ACCESS_KEY": "test",
		"SPRING_DATASOURCE_URL": "jdbc:postgresql://localhost:5432/nexus_connect",
		"SPRING_DATASOURCE_USERNAME": "postgres",
		"SPRING_DATASOURCE_PASSWORD": "postgres",
		"SPRING_DATASOURCE_MAX_POOL_SIZE": "10",
		"SPRING_DATASOURCE_MIN_IDLE": "5"
	},

	"postCreateCommand": "./gradlew --version",

	"remoteUser": "vscode"
}
